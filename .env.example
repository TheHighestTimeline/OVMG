# ─── Clerk Authentication ─────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → Your App → API Keys
# Copy the "Publishable key" (starts with pk_test_ or pk_live_)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Backend secret key (server-side only, never expose to client)
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get from https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Get from https://console.cloud.google.com → Credentials
GOOGLE_OAUTH_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_OAUTH_REDIRECT_URI=https://your-site.netlify.app/.netlify/functions/google-oauth-callback

# ─── Notion Integration ────────────────────────────────────────────────────────
# Get from https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OVMG main database
NOTION_OVMG_DB_ID=
# Social Clients tab databases (leave blank to use demo mode — see SOCIAL_SETUP.md)
NOTION_CLIENTS_DB_ID=
NOTION_POSTS_DB_ID=

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override the models used
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_PARSE_MODEL=gpt-4o-mini

# ─── Anthropic (Claude) — for Social AI Assistant + Campaign Builder ─────────
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Deepgram (alternate transcription) ──────────────────────────────────────
# Get from https://console.deepgram.com/
DEEPGRAM_API_KEY=

# ─── Netlify ──────────────────────────────────────────────────────────────────
# Get from https://app.netlify.com/user/applications#personal-access-tokens
NETLIFY_API_TOKEN=
# JSON array of site IDs to monitor, e.g. '["abc123","def456"]'
NETLIFY_SITE_IDS_JSON=

# ─── Zapier Webhooks ──────────────────────────────────────────────────────────
# Base URL for Zapier webhook triggers (no trailing slash)
ZAPIER_WEBHOOK_BASE=https://hooks.zapier.com/hooks/catch/xxxxxxx

# ─── Slack ────────────────────────────────────────────────────────────────────
# Get from https://api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_DEFAULT_CHANNEL=general

# ─── 1Password Connect (optional — for secrets injection in CI/CD) ────────────
ONEPASSWORD_CONNECT_HOST=https://your-connect-server.example.com
ONEPASSWORD_CONNECT_TOKEN=

# ─── Meta / Facebook ─────────────────────────────────────────────────────────
META_PIXEL_ID=
META_ACCESS_TOKEN=

# ─── Twilio ───────────────────────────────────────────────────────────────────
# Get from https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=

# ─── GitHub (for Websites tab — repo browsing, deploy status) ─────────────────
# Personal access token with repo + read:org scopes
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Airtable ─────────────────────────────────────────────────────────────────
# REQUIRED — get your token from https://airtable.com/create/tokens
# Scopes needed: data.records:read, data.records:write, schema.bases:read
AIRTABLE_TOKEN=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# REQUIRED — find in the URL of your base: airtable.com/appXXXXXXXXXXXXXX/...
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# ── Table IDs or exact table names (find in base URL or Airtable API docs) ─────
# If you set these to the table's tblXXXXXXXXXXXXXX ID it's more reliable than
# using names (names break if someone renames a table). Both formats work.

# REQUIRED for active migration targets:
AIRTABLE_TABLE_CONTACTS=CRM Contacts
AIRTABLE_TABLE_TASKS=Master Action Board
AIRTABLE_TABLE_OPPORTUNITIES=Opportunities
AIRTABLE_TABLE_COMPANIES=Companies
AIRTABLE_TABLE_NOTES=Notes
AIRTABLE_TABLE_OUTREACH=Outreach
AIRTABLE_TABLE_GOALS=Goals
AIRTABLE_TABLE_FINANCIAL=Financial

# OPTIONAL (not yet wired to Netlify functions but useful for future work):
AIRTABLE_TABLE_PROJECTS=Projects
AIRTABLE_TABLE_TIMELINE=Project Timeline
AIRTABLE_TABLE_CLIENT_POSTS=Client Posts
AIRTABLE_TABLE_CLIENTS=OVM Clients DB
AIRTABLE_TABLE_REFERENCE_LIBRARY=Reference Library
AIRTABLE_TABLE_ASSET_LIBRARY=Source Asset Library
