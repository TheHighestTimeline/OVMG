/* guide-dashboard styles */
* { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #0a0e1a;
  --panel: #111827;
  --panel-2: #1f2937;
  --border: #1f2937;
  --border-2: #374151;
  --text: #f9fafb;
  --text-2: #9ca3af;
  --text-3: #6b7280;
  --accent: #6366f1;
  --accent-2: #818cf8;
  --danger: #ef4444;
  --success: #10b981;
}

body {
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  font-size: 14px;
  min-height: 100vh;
}

header {
  background: var(--panel);
  border-bottom: 1px solid var(--border);
  padding: 16px 32px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
header h1 { font-size: 18px; font-weight: 700; letter-spacing: -0.02em; }
header p { font-size: 13px; color: var(--text-2); margin-top: 2px; }

main { max-width: 900px; margin: 0 auto; padding: 40px 24px; }

/* Upload zone */
.upload-zone {
  border: 2px dashed var(--border-2);
  border-radius: 12px;
  padding: 48px 32px;
  text-align: center;
  cursor: pointer;
  transition: all 0.2s;
  margin-bottom: 40px;
  position: relative;
}
.upload-zone:hover, .upload-zone.drag-over {
  border-color: var(--accent);
  background: rgba(99,102,241,0.05);
}
.upload-zone h2 { font-size: 18px; font-weight: 600; margin-bottom: 8px; }
.upload-zone p { font-size: 13px; color: var(--text-2); margin-bottom: 0; }
.upload-zone input[type="file"] {
  position: absolute;
  inset: 0;
  opacity: 0;
  cursor: pointer;
  width: 100%;
  height: 100%;
}
.upload-icon { font-size: 40px; margin-bottom: 16px; }

/* Upload form */
.upload-form { display: none; margin-top: 24px; }
.upload-form.visible { display: block; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
.form-group { display: flex; flex-direction: column; gap: 6px; }
.form-group label { font-size: 11px; font-weight: 600; color: var(--text-2); text-transform: uppercase; letter-spacing: 0.04em; }
.form-group input[type="text"] {
  padding: 8px 12px;
  background: var(--panel-2);
  border: 1px solid var(--border-2);
  border-radius: 6px;
  color: var(--text);
  font-size: 13px;
  font-family: inherit;
}
.form-group input:focus { outline: none; border-color: var(--accent); }
.file-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 12px;
  background: rgba(99,102,241,0.12);
  border: 1px solid var(--accent);
  border-radius: 6px;
  font-size: 12px;
  color: var(--accent-2);
  margin-bottom: 16px;
}

/* Buttons */
.btn {
  padding: 9px 18px;
  border: none;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  font-family: inherit;
  transition: all 0.15s;
}
.btn-primary { background: var(--accent); color: #fff; }
.btn-primary:hover { background: #4f46e5; }
.btn-secondary { background: var(--panel-2); color: var(--text); border: 1px solid var(--border-2); }
.btn-secondary:hover { background: var(--border-2); }
.btn-danger { background: transparent; color: var(--danger); border: 1px solid var(--danger); }
.btn-danger:hover { background: var(--danger); color: #fff; }
.btn:disabled { opacity: 0.5; cursor: not-allowed; }
.btn-row { display: flex; gap: 10px; margin-top: 4px; }

/* Progress */
#upload-progress { display: none; margin-top: 16px; }
.progress-bar-wrap { height: 6px; background: var(--border-2); border-radius: 3px; overflow: hidden; margin-bottom: 8px; }
.progress-bar-fill { height: 100%; background: var(--accent); border-radius: 3px; transition: width 0.3s; }
.progress-label { font-size: 12px; color: var(--text-2); }

/* Section heading */
.section-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-2);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* Guide cards */
.guide-grid { display: flex; flex-direction: column; gap: 12px; }
.guide-card {
  background: var(--panel);
  border: 1px solid var(--border-2);
  border-radius: 10px;
  padding: 18px 20px;
  display: flex;
  align-items: center;
  gap: 20px;
}
.guide-card-info { flex: 1; min-width: 0; }
.guide-card-title { font-size: 15px; font-weight: 600; margin-bottom: 4px; }
.guide-card-meta { font-size: 12px; color: var(--text-3); margin-bottom: 8px; }
.guide-card-url {
  font-size: 12px;
  color: var(--accent-2);
  text-decoration: none;
  word-break: break-all;
}
.guide-card-url:hover { text-decoration: underline; }
.guide-actions { display: flex; gap: 8px; flex-shrink: 0; }

/* Embed code */
.embed-popup {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.7);
  z-index: 100;
  align-items: center;
  justify-content: center;
  padding: 20px;
}
.embed-popup.visible { display: flex; }
.embed-box {
  background: var(--panel);
  border: 1px solid var(--border-2);
  border-radius: 12px;
  padding: 24px;
  width: 560px;
  max-width: 100%;
}
.embed-box h2 { font-size: 16px; margin-bottom: 8px; }
.embed-box p { font-size: 13px; color: var(--text-2); margin-bottom: 16px; }
.embed-code {
  background: var(--panel-2);
  border: 1px solid var(--border-2);
  border-radius: 6px;
  padding: 12px 14px;
  font-family: monospace;
  font-size: 12px;
  color: var(--accent-2);
  word-break: break-all;
  white-space: pre-wrap;
  margin-bottom: 16px;
  cursor: pointer;
}
.embed-code:hover { border-color: var(--accent); }
.embed-actions { display: flex; justify-content: flex-end; gap: 8px; }

/* Toast */
#toast {
  position: fixed;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%) translateY(80px);
  background: var(--panel);
  border: 1px solid var(--border-2);
  border-radius: 8px;
  padding: 10px 20px;
  font-size: 13px;
  font-weight: 500;
  box-shadow: 0 8px 24px rgba(0,0,0,0.4);
  transition: transform 0.25s ease;
  z-index: 200;
  white-space: nowrap;
}
#toast.visible { transform: translateX(-50%) translateY(0); }
#toast.success { border-color: var(--success); color: var(--success); }
#toast.error { border-color: var(--danger); color: var(--danger); }

.empty-state {
  text-align: center;
  padding: 48px 20px;
  color: var(--text-3);
}
.empty-state h3 { font-size: 16px; margin-bottom: 8px; color: var(--text-2); }
.loading { text-align: center; padding: 32px; color: var(--text-3); font-size: 13px; }
